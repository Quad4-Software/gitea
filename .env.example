# Copy to .env and change secrets before running: cp .env.example .env

USER_UID=1000
USER_GID=1000

GITEA__server__DOMAIN=localhost
GITEA__server__ROOT_URL=http://localhost:3000/
GITEA__server__SSH_DOMAIN=localhost
GITEA__security__SECRET_KEY=change-me-use-openssl-rand-hex-32
GITEA__service__DISABLE_REGISTRATION=false

GITEA__reticulum__ENABLED=true
GITEA__reticulum__START_BUILTIN_SERVER=true
GITEA__reticulum__RNS_CONFIG_PATH=/data/gitea/reticulum/network
